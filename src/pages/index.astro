---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Diego Medina.">
	<main>
		<section class="screen">
			<h2>
				Hey there <img src="data:image/png;base64,">
			</h2>
			<h1>I'm Diego Medina</h1>
			<h4>Frontend Developer & Web Designer</h4>
			
			<div>
				<span class="experience"><b>8</b> years <br> experience</span>
				<span class="location">
					Argentina
					<img src="data:image/png;base64,">
				</span>
			</div>
		</section>
		<section class="experience">
			<h1 class="title">Experience.</h1>
			<article>
				<span>Jun. 2019 - Present (4 years, 6 months)<br>Argentina</span>
				<b>Pirca Solutions</b>
				<p>
					Front-end developer for administration projects, radio/video automation and products related to video calls
				</p>
			</article>
			<article>
				<span>Jan. 2019 - Jun. 2019 (6 months)<br>Argentina</span>
				<b>Ego Agency</b>
				<p>
					Front-end developer at Bank Santander for Home Banking project, in the Investment area.
				</p>
			</article>
			<article>
				<span>Dec. 2015 - Jan.2019 (3 years, 2 months)<br>Argentina</span>
				<b>Viajobien.com</b>
				<p>
					Front-end developer in the products Hotels, Tourist Packages, Build your trip, Assistance and Backoffice for several countries (Argentina, Chile, Uruguay).
				</p>
			</article>
		</section>
		<section class="aboutme">
			<h1 class="title">About me.</h1>
			<img src="/personal/about-me.jpg" alt="Diego Medina">
			<p>I'm Diego Medina, a front-end developer with over 8 years of experience in the web industry. I currently live in Buenos Aires, Argentina, and I'm passionate about web development. Since I started in the industry, I have worked on challenging projects that have allowed me to learn and grow professionally. I am always looking for new ways to improve my skills and learn new technologies.</p>
		
			<ul>
				<li>
					<img src="data:image/png;base64,">
				</li>
				<li>
					<img src="data:image/png;base64,">
				</li>
				<li>
					<img src="data:image/png;base64,">
				</li>
			</ul>
		</section>
		<section class="works">
			<h1 class="title">Works.</h1>
			<article>
				<img src="/personal/sebastian.png" alt="Sebastian Perez">
				<a href="">Visit site</a>
			</article>
		</section>
		<section>
		</section>
	</main>
	<footer>
		<b>DM.</b>
		<span>Made with ❤️</span>
	</footer>
</Layout>

<style>
	header {
		color: white;
	}
	main {
		margin: auto;
		padding: 1rem;
		width: 1200px;
		max-width: calc(100% - 2rem);
		color: white;
		line-height: 1.6;
		overflow-x: hidden;
	}
	.title {
		font-size: 2rem;
		font-weight: 600;
		color: #fff;
		text-align: center;
	}
	.screen {
		height: 100svh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding-top: 15rem;

		h1, h2, h4 {
			margin: 0;
		}

		h1 {
			font-size: 2.4rem;
			font-weight: bold;
			line-height: 2rem;
			margin-bottom: 16px;
		}

		h2 {
			font-size: 2rem;
			font-weight: lighter;
			display: flex;
			gap: 8px;
		}

		h4 {
			color: #8b949e;
			font-weight: lighter;
		}

		div {
			display: flex;
			justify-content: space-between;
			align-items: flex-end;
			margin-top: auto;
			margin-bottom: 4rem;
		}

		.experience {
			text-transform: uppercase;
			display: flex;
			gap: 8px;
			align-items: center;
			line-height: 1.3rem;

			b {
				font-size: 3rem;
			}
		}

		.location {
			display: flex;
			gap: 8px;
			align-items: center;
			color: #8b949e;
			margin-bottom: -.2rem;
		}
	}
	.experience {
		article {
			display: flex;
			flex-direction: column;
			gap: 4px;
			margin: 2rem 0;
			position: relative;

			&::before {
				content: '';
				background: linear-gradient(#706be0, #0b1345);
				width: 1px;
				height: 100%;
				left: -12px;
				top: 0px;
				position: absolute;
			}
			
			span {
				font-weight: lighter;
			}

			b {
				font-weight: bold;
				font-size: 1.2rem;
			}

			p {
				margin: 0;
			}
		
		}
	}
	.aboutme {
		img {
			border-radius: 12px;
		}

		ul {
			list-style: none;
			display: flex;
			justify-content: center;
			gap: 12px;
			margin: 0;
			padding: 0;

			li {
				border-top: 1px solid #717171;
				background: linear-gradient(#404040, #1f1f1f);
				border-radius: 12px;
				padding: 4px 8px;
				width: 50px;
				aspect-ratio: 1;	
				display: flex;
				justify-content: center;
				align-items: center;

				img {
					width: 32px;
				}
			}
		}
	}
	.works {
		article {
			position: relative;

			img {
				border-radius: 12px;
			}
	
			a {
				position: absolute;
				bottom: 4px;
				right: 4px;
				background: rgba(0, 0, 0, .5);
				border: 1px solid #ffffff33;
				backdrop-filter: blur(12px);
				padding: 2px 12px;
				border-radius: 12px;
				text-transform: uppercase;
				text-decoration: none;
				color: #ffffffb3;
				font-size: .8rem;
				font-weight: 400;
			}
		}
	}
	footer {
		padding: 12px 0px;
		max-width: calc(100% - 2rem);
		margin: auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		color: rgba(255, 255, 255, 0.5);
		font-weight: lighter;
		
		b {
			font-weight: bold;
		}
	}


</style>
